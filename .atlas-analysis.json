  "keyFeatures": [
    "Real-time face detection using camera feed",
    "Single and multiple user face capture",
    "Face++ API integration for recognition",
    "User registration with face tokens",
    "SQLite database for user management",
    "Admin dashboard with system controls",
    "FaceSet backup and restore capabilities",
    "Face comparison and verification",
    "Google OAuth authentication for admin",
    "Image augmentation and processing"
  ],
  "publicApiSurface": [
    "/capture_single - Single face detection endpoint",
    "/capture_multiple - Multiple face detection endpoint",
    "/register - User registration with face data",
    "/register_multiple - Bulk user registration",
    "/compare_images - Face comparison endpoint",
    "/reset_system - System reset (OAuth protected)",
    "/create_database - Database initialization",
    "/populate_database - Bulk database population",
    "/verify_faceset - FaceSet verification",
    "/list_faces - List all registered faces",
    "/event_info - Event user information",
    "detect_faces_sync() - Synchronous face detection",
    "search_face_sync() - Face search with caching",
    "reset_faceset() - FaceSet reset helper",
    "reset_sqlite() - Database reset helper"
  ]
